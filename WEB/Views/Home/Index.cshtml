@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    ViewData["PageTitle"] = "Visão Geral";
    ViewData["PageSubtitle"] = "Acompanhe as métricas e alertas da sua loja.";
}

<div class="row">
    <div class="col-12 text-center mt-5 pt-5">
        <div class="display-1 text-muted mb-4" style="opacity: 0.2;">
            <i class="fas fa-chart-line"></i>
        </div>
        <h3 class="text-secondary fw-bold">Bem-vindo ao Painel Administrativo!</h3>
        <p class="text-muted">A tela de relatórios e métricas avançadas será implementada nas próximas fases.</p>
        
        <a asp-controller="Produto" asp-action="Index" class="btn btn-danger-custom mt-3">
            <i class="fas fa-box-open ms-1"></i> Ir para Produtos
        </a>
    </div>
</div>
