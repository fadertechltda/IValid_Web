@using DOMAIN.Model.Produto
@model ProdutoModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Excluir Produto";
    ViewData["ActivePage"] = "Produto";
    ViewData["PageTitle"] = "Confirmar Exclusão";
    ViewData["PageSubtitle"] = "Esta ação não pode ser desfeita";

    var statusUpper = Model?.Status?.ToUpper() ?? "VERDE";
    string statusClass = statusUpper == "VERMELHO" ? "badge-vermelho" : statusUpper == "AMARELO" ? "badge-amarelo" : "badge-verde";
    string statusLabel = statusUpper == "VERMELHO" ? "Crítico" : statusUpper == "AMARELO" ? "Atenção" : "Na Validade";
    var dias = Model != null ? (Model.DataVencimento - DateTime.Now.Date).Days : 0;
}

<div class="row justify-content-center">
    <div class="col-xl-6">

        <div class="mb-4 p-4 text-center"
             style="background:linear-gradient(135deg,#ffebee,#fff8e1);border-radius:16px;border:2px dashed var(--vermelho);">
            <div style="width:64px;height:64px;background:var(--vermelho-light);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                <i class="fas fa-trash-alt" style="font-size:26px;color:var(--vermelho);"></i>
            </div>
            <div style="font-size:18px;font-weight:800;color:var(--vermelho);">Excluir Produto?</div>
            <div style="font-size:13px;color:#888;margin-top:4px;">Esta ação é permanente e não poderá ser desfeita.</div>
        </div>

        <div class="admin-card mb-4">
            <div class="admin-card-header">
                <h2 class="admin-card-title"><i class="fas fa-box-open me-2" style="color:#aaa;"></i>Dados do Produto</h2>
                <span class="@statusClass">@statusLabel</span>
            </div>
            <div class="p-4">
                <div class="d-flex align-items-center gap-4 mb-4">
                    @if (!string.IsNullOrEmpty(Model?.UrlImagem))
                    {
                        <img src="@Model.UrlImagem" alt="@Model?.Nome"
                             style="width:70px;height:70px;object-fit:cover;border-radius:14px;border:2px solid #eee;">
                    }
                    else
                    {
                        <div style="width:70px;height:70px;border-radius:14px;background:#f0f2f6;display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-image" style="font-size:24px;color:#ccc;"></i>
                        </div>
                    }
                    <div>
                        <div style="font-size:18px;font-weight:800;color:#1a1a2e;">@Model?.Nome</div>
                        <div style="font-size:12px;color:#aaa;margin-top:2px;">@Model?.Id</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div style="background:#f8f9fc;border-radius:10px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;">Preço Original</div>
                            <div style="font-size:16px;font-weight:700;color:#1a1a2e;margin-top:4px;">R$ @Model?.Preco.ToString("F2")</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div style="background:#ffebee;border-radius:10px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--vermelho);">Preço Promo</div>
                            <div style="font-size:16px;font-weight:700;color:var(--vermelho);margin-top:4px;">R$ @Model?.PrecoPromocao.ToString("F2")</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:#f8f9fc;border-radius:10px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;">Estoque</div>
                            <div style="font-size:16px;font-weight:700;color:#1a1a2e;margin-top:4px;">@Model?.Quantidade un.</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:#f8f9fc;border-radius:10px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;">Desconto</div>
                            <div style="font-size:16px;font-weight:700;color:#1a1a2e;margin-top:4px;">@Model?.DescricaoPorcentual%</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div style="background:#f8f9fc;border-radius:10px;padding:12px;">
                            <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#aaa;">Vencimento</div>
                            <div style="font-size:13px;font-weight:700;color:@(dias <= 10 ? "var(--vermelho)" : dias <= 20 ? "var(--amarelo)" : "var(--verde)");margin-top:4px;">
                                @Model?.DataVencimento.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <form asp-controller="Produto" asp-action="Delete" asp-route-id="@Model?.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-3">
                <a asp-controller="Produto" asp-action="Index"
                   class="btn-outline-custom flex-grow-1 text-center" style="text-decoration:none; padding:12px;">
                    <i class="fas fa-arrow-left me-1"></i> Cancelar
                </a>
                <button type="submit" class="btn-danger-custom flex-grow-1"
                        style="padding:12px;" onclick="return confirm('Tem certeza que deseja excluir este produto?');">
                    <i class="fas fa-trash-alt me-1"></i> Confirmar Exclusão
                </button>
            </div>
        </form>

    </div>
</div>
