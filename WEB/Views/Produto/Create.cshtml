@using DOMAIN.Model
@model ProdutoModel

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Novo Produto";
    ViewData["ActivePage"] = "Produto";
    ViewData["PageTitle"] = "Cadastrar Produto";
    ViewData["PageSubtitle"] = "Preencha os dados para adicionar um novo produto";
}

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title"><i class="fas fa-plus-circle me-2" style="color:var(--verde)"></i>Novo Produto</h2>
                <a asp-controller="Produto" asp-action="Index" class="btn-outline-custom" style="text-decoration:none; font-size:13px;">
                    <i class="fas fa-arrow-left me-1"></i> Voltar
                </a>
            </div>

            <div class="p-4">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-admin danger mb-4">
                        <i class="fas fa-exclamation-circle"></i>
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form asp-controller="Produto" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">

                        <!-- Nome -->
                        <div class="col-12">
                            <label class="form-label-custom">Nome do Produto *</label>
                            <input asp-for="Nome" class="form-control form-control-custom w-100"
                                   placeholder="Ex: Filé de Frango Sadia 1kg" />
                            <span asp-validation-for="Nome" class="text-danger" style="font-size:12px;"></span>
                        </div>

                        <!-- Preço Original -->
                        <div class="col-md-6">
                            <label class="form-label-custom">Preço Original (R$) *</label>
                            <div class="input-group">
                                <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1.5px solid #e8eaef; background:#f8f9fc; font-size:13px; border-right:none;">R$</span>
                                <input asp-for="Preco" type="number" step="0.01" min="0.01"
                                       class="form-control form-control-custom"
                                       style="border-left:none; border-radius:0 10px 10px 0;"
                                       placeholder="0,00" />
                            </div>
                            <span asp-validation-for="Preco" class="text-danger" style="font-size:12px;"></span>
                        </div>

                        <!-- Quantidade -->
                        <div class="col-md-6">
                            <label class="form-label-custom">Quantidade em Estoque *</label>
                            <input asp-for="Quantidade" type="number" min="0"
                                   class="form-control form-control-custom w-100" placeholder="0" />
                            <span asp-validation-for="Quantidade" class="text-danger" style="font-size:12px;"></span>
                        </div>

                        <!-- Data de Vencimento -->
                        <div class="col-12">
                            <label class="form-label-custom">Data de Vencimento *</label>
                            <input asp-for="DataVencimento" type="date"
                                   class="form-control form-control-custom w-100" />
                            <span asp-validation-for="DataVencimento" class="text-danger" style="font-size:12px;"></span>
                        </div>

                        <!-- URL Imagem (opcional) -->
                        <div class="col-12">
                            <label class="form-label-custom">URL da Imagem <span style="color:#aaa;font-weight:400;">(opcional)</span></label>
                            <input asp-for="UrlImagem" type="url"
                                   class="form-control form-control-custom w-100"
                                   placeholder="https://..." />
                            <span asp-validation-for="UrlImagem" class="text-danger" style="font-size:12px;"></span>
                        </div>

                        <!-- Info campos automáticos -->
                        <div class="col-12">
                            <div style="background: linear-gradient(135deg, #e8f5e9, #f1f8e9); border-radius:12px; padding:16px; border-left:4px solid var(--verde);">
                                <div style="font-size:12px; font-weight:700; color:var(--verde); margin-bottom:8px;">
                                    <i class="fas fa-magic me-1"></i> Campos calculados automaticamente pela API
                                </div>
                                <div class="row g-2" style="font-size:12px; color:#555;">
                                    <div class="col-sm-4">
                                        <span style="display:inline-block;width:10px;height:10px;background:var(--vermelho);border-radius:50%;margin-right:4px;"></span>
                                        <strong>VERMELHO</strong> ≤ 10 dias → 50% OFF
                                    </div>
                                    <div class="col-sm-4">
                                        <span style="display:inline-block;width:10px;height:10px;background:var(--amarelo);border-radius:50%;margin-right:4px;"></span>
                                        <strong>AMARELO</strong> ≤ 20 dias → 20% OFF
                                    </div>
                                    <div class="col-sm-4">
                                        <span style="display:inline-block;width:10px;height:10px;background:var(--verde);border-radius:50%;margin-right:4px;"></span>
                                        <strong>VERDE</strong> &gt; 20 dias → sem desconto
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Botões -->
                        <div class="col-12 d-flex justify-content-end gap-3 pt-2">
                            <a asp-controller="Produto" asp-action="Index" class="btn-outline-custom" style="text-decoration:none;">
                                <i class="fas fa-times me-1"></i> Cancelar
                            </a>
                            <button type="submit" class="btn-success-custom">
                                <i class="fas fa-save me-1"></i> Salvar Produto
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
