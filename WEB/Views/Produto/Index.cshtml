@using DOMAIN.Model
@model List<ProdutoModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Produtos";
    ViewData["ActivePage"] = "Produto";
    ViewData["PageTitle"] = "Gestão de Produtos";
    ViewData["PageSubtitle"] = "Visualize, cadastre e gerencie os produtos do sistema";
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card danger">
            <div class="stat-icon danger"><i class="fas fa-fire"></i></div>
            <div class="stat-value" id="count-vermelho">0</div>
            <div class="stat-label">🔴 Críticos (≤10 dias)</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card warning">
            <div class="stat-icon warning"><i class="fas fa-exclamation-triangle"></i></div>
            <div class="stat-value" id="count-amarelo">0</div>
            <div class="stat-label">🟡 Atenção (≤20 dias)</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card success">
            <div class="stat-icon success"><i class="fas fa-check-circle"></i></div>
            <div class="stat-value" id="count-verde">0</div>
            <div class="stat-label">🟢 Na validade</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card info">
            <div class="stat-icon info"><i class="fas fa-boxes"></i></div>
            <div class="stat-value" id="count-total">@(Model?.Count ?? 0)</div>
            <div class="stat-label">Total de produtos</div>
        </div>
    </div>
</div>

<div class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title"><i class="fas fa-box-open me-2" style="color:var(--vermelho)"></i>Lista de Produtos</h2>
        <div class="d-flex gap-2 align-items-center">
            <div class="input-group" style="width:220px;">
                <span class="input-group-text" style="border-radius:10px 0 0 10px; border:1.5px solid #e8eaef; background:#f8f9fc; border-right:none;">
                    <i class="fas fa-search text-muted" style="font-size:12px;"></i>
                </span>
                <input type="text" id="searchInput" class="form-control-custom" placeholder="Buscar produto..."
                       style="border-left:none; border-radius:0 10px 10px 0; height:38px;" oninput="filtrarTabela()">
            </div>
            <a asp-controller="Produto" asp-action="Create" class="btn-danger-custom d-flex align-items-center gap-2" style="text-decoration:none;">
                <i class="fas fa-plus"></i> Novo Produto
            </a>
        </div>
    </div>

    <div class="table-responsive">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-box-open" style="font-size:48px; color:#ddd;"></i>
                <p class="mt-3" style="color:#aaa; font-size:14px;">Nenhum produto cadastrado ainda.</p>
                <a asp-controller="Produto" asp-action="Create" class="btn-danger-custom" style="text-decoration:none;">
                    <i class="fas fa-plus me-1"></i> Cadastrar Primeiro Produto
                </a>
            </div>
        }
        else
        {
            <table class="table admin-table mb-0" id="produtosTable">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Status</th>
                        <th>Preço Original</th>
                        <th>Preço Promo</th>
                        <th>Desconto</th>
                        <th>Qtd.</th>
                        <th>Vencimento</th>
                        <th style="text-align:center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var produto in Model)
                    {
                        <tr data-status="@produto.Status?.ToUpper()">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(produto.UrlImagem))
                                    {
                                        <img src="@produto.UrlImagem" alt="@produto.Nome"
                                             style="width:42px;height:42px;object-fit:cover;border-radius:10px;border:1.5px solid #eee;">
                                    }
                                    else
                                    {
                                        <div style="width:42px;height:42px;border-radius:10px;background:#f0f2f6;display:flex;align-items:center;justify-content:center;">
                                            <i class="fas fa-image" style="color:#ccc;font-size:14px;"></i>
                                        </div>
                                    }
                                    <div>
                                        <div style="font-weight:600;font-size:13px;color:#1a1a2e;">@produto.Nome</div>
                                        <div style="font-size:11px;color:#aaa;">ID: @(produto.Id?.Substring(0, 8))...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @{
                                    var statusUpper = produto.Status?.ToUpper() ?? "";
                                    string badgeClass = statusUpper == "VERMELHO" ? "badge-vermelho" :
                                                        statusUpper == "AMARELO"  ? "badge-amarelo"  : "badge-verde";
                                    string statusLabel = statusUpper == "VERMELHO" ? "Crítico" :
                                                         statusUpper == "AMARELO"  ? "Atenção"  : "Na Validade";
                                }
                                <span class="@badgeClass">@statusLabel</span>
                            </td>
                            <td style="font-weight:600;">R$ @produto.Preco.ToString("F2")</td>
                            <td style="color:var(--vermelho); font-weight:700;">R$ @produto.PrecoPromocao.ToString("F2")</td>
                            <td>
                                <span style="background:#f0f2f6; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:700; color:#555;">
                                    @produto.DescricaoPorcentual%
                                </span>
                            </td>
                            <td>@produto.Quantidade</td>
                            <td>
                                @{
                                    var dias = (produto.DataVencimento - DateTime.Now.Date).Days;
                                    string diaColor = dias <= 10 ? "var(--vermelho)" : dias <= 20 ? "var(--amarelo)" : "var(--verde)";
                                }
                                <div style="font-size:12px; font-weight:600; color:@diaColor;">
                                    @produto.DataVencimento.ToString("dd/MM/yyyy")
                                </div>
                                <div style="font-size:11px; color:#aaa;">@dias dias restantes</div>
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-controller="Produto" asp-action="Edit" asp-route-id="@produto.Id"
                                       class="btn-icon edit" title="Editar">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <a asp-controller="Produto" asp-action="Delete" asp-route-id="@produto.Id"
                                       class="btn-icon delete" title="Excluir">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script>
    // Contagem dos cards de status
    document.addEventListener('DOMContentLoaded', () => {
        const rows = document.querySelectorAll('#produtosTable tbody tr');
        let v = 0, a = 0, g = 0;
        rows.forEach(r => {
            const s = r.dataset.status;
            if (s === 'VERMELHO') v++;
            else if (s === 'AMARELO') a++;
            else g++;
        });
        document.getElementById('count-vermelho').textContent = v;
        document.getElementById('count-amarelo').textContent  = a;
        document.getElementById('count-verde').textContent    = g;
    });

    // Filtro de busca
    function filtrarTabela() {
        const q = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('#produtosTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    }
</script>
}
