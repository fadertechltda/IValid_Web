@using DOMAIN.Model.Produto
@model List<ProdutoModel>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Produtos";
    ViewData["ActivePage"] = "Produto";
    ViewData["PageTitle"] = "Gestão de Produtos";
    ViewData["PageSubtitle"] = "Visualize, cadastre e gerencie os produtos do sistema";
}

@await Component.InvokeAsync("EstatisticasProdutos", new { produtos = Model })

<div class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title"><i class="fas fa-box-open me-2" style="color:var(--vermelho)"></i>Lista de Produtos</h2>
        <div class="d-flex gap-2 align-items-center">
            <div class="position-relative" style="width: 250px;">
                <i class="fas fa-search text-muted position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 14px;"></i>
                <input type="text" id="campoBusca" class="form-control" placeholder="Buscar produto..."
                       style="padding-left: 38px; border-radius: 10px; border: 1.5px solid #e8eaef; font-size: 14px; height: 42px; box-shadow: none;" oninput="filtrarTabela()">
            </div>
            <a asp-controller="Produto" asp-action="Create" class="btn-danger-custom d-flex align-items-center gap-2" style="text-decoration:none;">
                <i class="fas fa-plus"></i> Novo Produto
            </a>
        </div>
    </div>

    <div class="table-responsive">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-box-open" style="font-size:48px; color:#ddd;"></i>
                <p class="mt-3" style="color:#aaa; font-size:14px;">Nenhum produto cadastrado ainda.</p>
                <a asp-controller="Produto" asp-action="Create" class="btn-danger-custom" style="text-decoration:none;">
                    <i class="fas fa-plus me-1"></i> Cadastrar Primeiro Produto
                </a>
            </div>
        }
        else
        {
            <table class="table admin-table mb-0" id="tabelaProdutos">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Status</th>
                        <th>Preço Original</th>
                        <th>Preço Promo</th>
                        <th>Desconto</th>
                        <th>Qtd.</th>
                        <th>Vencimento</th>
                        <th style="text-align:center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var produto in Model)
                    {
                        <tr data-status="@produto.Status?.ToUpper()">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @{ ViewData["Tamanho"] = "P"; }
                                    @await Html.PartialAsync("~/Views/Shared/Componentes/_ImagemProduto.cshtml", produto.UrlImagem)

                                    <div>
                                        <div style="font-weight:600;font-size:13px;color:#1a1a2e;">@produto.Nome</div>
                                        <div style="font-size:11px;color:#aaa;">ID: @(produto.Id?.Substring(0, 8))...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @await Html.PartialAsync("~/Views/Shared/Componentes/_BadgeStatus.cshtml", produto.Status)
                            </td>
                            <td style="font-weight:600;">R$ @produto.Preco.ToString("F2")</td>
                            <td style="color:var(--vermelho); font-weight:700;">R$ @produto.PrecoPromocao.ToString("F2")</td>
                            <td>
                                <span style="background:#f0f2f6; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:700; color:#555;">
                                    @produto.DescricaoPorcentual%
                                </span>
                            </td>
                            <td>@produto.Quantidade</td>
                            <td>
                                @{
                                    var diasRestantes = (produto.DataVencimento - DateTime.Now.Date).Days;
                                    string corDias = diasRestantes <= 10 ? "var(--vermelho)" : diasRestantes <= 20 ? "var(--amarelo)" : "var(--verde)";
                                }
                                <div style="font-size:12px; font-weight:600; color:@corDias;">
                                    @produto.DataVencimento.ToString("dd/MM/yyyy")
                                </div>
                                <div style="font-size:11px; color:#aaa;">@diasRestantes dias restantes</div>
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-controller="Produto" asp-action="Edit" asp-route-id="@produto.Id"
                                       class="btn-icon edit" title="Editar">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <a asp-controller="Produto" asp-action="Delete" asp-route-id="@produto.Id"
                                       class="btn-icon delete" title="Excluir">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@section Scripts {
<script>
    function removerAcentos(texto) {
        return texto.normalize('NFD').replace(/[\u0300-\u036f]/g, "");
    }

    function filtrarTabela() {
        const termoBusca = removerAcentos(document.getElementById('campoBusca').value.toLowerCase());
        document.querySelectorAll('#tabelaProdutos tbody tr').forEach(linha => {
            const textoLinha = removerAcentos(linha.textContent.toLowerCase());
            linha.style.display = textoLinha.includes(termoBusca) ? '' : 'none';
        });
    }
</script>
}
