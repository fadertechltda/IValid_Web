<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IValid Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --vermelho: #E53935;
            --vermelho-dark: #B71C1C;
            --vermelho-light: #FFEBEE;
            --amarelo: #F9A825;
            --amarelo-light: #FFF8E1;
            --verde: #2E7D32;
            --verde-light: #E8F5E9;
            --sidebar-bg: #1a1a2e;
            --sidebar-width: 260px;
            --topbar-height: 64px;
            --text-muted-custom: #8a8fa3;
            --bg-page: #f4f6fb;
        }

        * { font-family: 'Inter', sans-serif; }
        body { background: var(--bg-page); overflow-x: hidden; }

        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            box-shadow: 4px 0 20px rgba(0,0,0,0.3);
        }

        .sidebar-brand {
            padding: 20px 24px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .brand-logo {
            width: 40px; height: 40px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--vermelho) 0%, var(--amarelo) 50%, var(--verde) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 18px;
            color: white;
            box-shadow: 0 4px 12px rgba(229,57,53,0.4);
        }

        .brand-text { color: white; font-weight: 700; font-size: 20px; letter-spacing: 1px; }
        .brand-text span { color: var(--vermelho); }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-title {
            padding: 8px 24px;
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted-custom);
            margin-top: 8px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 24px;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-radius: 0;
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
            position: relative;
        }

        .sidebar-link:hover {
            color: white;
            background: rgba(255,255,255,0.06);
            border-left-color: var(--amarelo);
        }

        .sidebar-link.active {
            color: white;
            background: rgba(229,57,53,0.15);
            border-left-color: var(--vermelho);
        }

        .sidebar-link .icon {
            width: 20px;
            text-align: center;
            font-size: 15px;
        }

        .sidebar-link .badge-count {
            margin-left: auto;
            background: var(--vermelho);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 20px;
        }

        .sidebar-footer {
            padding: 16px 24px;
            border-top: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--vermelho), var(--amarelo));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 14px;
        }

        .user-name { color: white; font-size: 13px; font-weight: 600; }
        .user-role { color: var(--text-muted-custom); font-size: 11px; }

        #topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: white;
            z-index: 900;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            border-bottom: 1px solid #eef0f4;
        }

        .topbar-title { font-size: 18px; font-weight: 700; color: #1a1a2e; }
        .topbar-subtitle { font-size: 12px; color: var(--text-muted-custom); margin-top: 1px; }

        .topbar-actions { display: flex; align-items: center; gap: 12px; }

        .topbar-icon-btn {
            width: 38px; height: 38px;
            border-radius: 10px;
            background: var(--bg-page);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #555;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .topbar-icon-btn:hover { background: var(--vermelho-light); color: var(--vermelho); }

        .notif-dot {
            position: absolute;
            top: 6px; right: 6px;
            width: 8px; height: 8px;
            background: var(--vermelho);
            border-radius: 50%;
            border: 2px solid white;
        }

        #main-content {
            margin-left: var(--sidebar-width);
            padding-top: var(--topbar-height);
            min-height: 100vh;
        }

        .page-wrapper { padding: 28px; }

        .admin-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.06);
            border: 1px solid #eef0f4;
            overflow: hidden;
        }

        .admin-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 24px;
            border-bottom: 1px solid #eef0f4;
        }

        .admin-card-title { font-size: 15px; font-weight: 700; color: #1a1a2e; margin: 0; }

        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 22px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.06);
            border: 1px solid #eef0f4;
            position: relative;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.1); }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
        }

        .stat-card.danger::before { background: linear-gradient(90deg, var(--vermelho), #ff5252); }
        .stat-card.warning::before { background: linear-gradient(90deg, var(--amarelo), #ffd740); }
        .stat-card.success::before { background: linear-gradient(90deg, var(--verde), #4CAF50); }
        .stat-card.info::before { background: linear-gradient(90deg, #1565C0, #42a5f5); }

        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 14px;
        }

        .stat-icon.danger { background: var(--vermelho-light); color: var(--vermelho); }
        .stat-icon.warning { background: var(--amarelo-light); color: var(--amarelo); }
        .stat-icon.success { background: var(--verde-light); color: var(--verde); }
        .stat-icon.info { background: #e3f2fd; color: #1565C0; }

        .stat-value { font-size: 28px; font-weight: 800; color: #1a1a2e; line-height: 1; }
        .stat-label { font-size: 12px; font-weight: 500; color: var(--text-muted-custom); margin-top: 4px; }

        .badge-vermelho { background: var(--vermelho-light); color: var(--vermelho); font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; display: inline-flex; align-items: center; gap: 5px; }
        .badge-amarelo  { background: var(--amarelo-light); color: #e65100; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; display: inline-flex; align-items: center; gap: 5px; }
        .badge-verde    { background: var(--verde-light); color: var(--verde); font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 20px; display: inline-flex; align-items: center; gap: 5px; }

        .badge-vermelho::before { content: ''; width: 6px; height: 6px; background: var(--vermelho); border-radius: 50%; }
        .badge-amarelo::before  { content: ''; width: 6px; height: 6px; background: var(--amarelo); border-radius: 50%; }
        .badge-verde::before    { content: ''; width: 6px; height: 6px; background: var(--verde); border-radius: 50%; }

        .admin-table thead th {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted-custom);
            background: #f8f9fc;
            border-bottom: 1px solid #eef0f4;
            padding: 12px 16px;
        }

        .admin-table tbody td {
            font-size: 13px;
            padding: 14px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #f0f2f6;
            color: #333;
        }

        .admin-table tbody tr:hover { background: #fafbff; }
        .admin-table tbody tr:last-child td { border-bottom: none; }

        .btn-danger-custom {
            background: var(--vermelho);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            padding: 9px 20px;
            font-size: 13px;
            transition: all 0.2s;
        }
        .btn-danger-custom:hover { background: var(--vermelho-dark); color: white; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(229,57,53,0.4); }

        .btn-warning-custom {
            background: var(--amarelo);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            padding: 9px 20px;
            font-size: 13px;
            transition: all 0.2s;
        }
        .btn-warning-custom:hover { background: #e65100; color: white; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(249,168,37,0.4); }

        .btn-success-custom {
            background: var(--verde);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            padding: 9px 20px;
            font-size: 13px;
            transition: all 0.2s;
        }
        .btn-success-custom:hover { background: #1B5E20; color: white; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(46,125,50,0.4); }

        .btn-outline-custom {
            background: transparent;
            color: #555;
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            font-weight: 600;
            padding: 9px 20px;
            font-size: 13px;
            transition: all 0.2s;
        }
        .btn-outline-custom:hover { background: #f4f6fb; border-color: #bbb; }

        .btn-icon {
            width: 34px; height: 34px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            border: none;
            transition: all 0.2s;
            cursor: pointer;
        }
        .btn-icon.edit { background: #e3f2fd; color: #1565C0; }
        .btn-icon.edit:hover { background: #1565C0; color: white; }
        .btn-icon.delete { background: var(--vermelho-light); color: var(--vermelho); }
        .btn-icon.delete:hover { background: var(--vermelho); color: white; }
        .btn-icon.view { background: var(--verde-light); color: var(--verde); }
        .btn-icon.view:hover { background: var(--verde); color: white; }

        .form-label-custom { font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
        .form-control-custom {
            border: 1.5px solid #e8eaef;
            border-radius: 10px;
            font-size: 14px;
            padding: 10px 14px;
            transition: all 0.2s;
            color: #333;
        }
        .form-control-custom:focus { border-color: var(--vermelho); box-shadow: 0 0 0 3px rgba(229,57,53,0.12); outline: none; }

        .alert-admin {
            border-radius: 12px;
            border: none;
            font-size: 13px;
            font-weight: 500;
            padding: 12px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .alert-admin.success { background: var(--verde-light); color: var(--verde); }
        .alert-admin.danger  { background: var(--vermelho-light); color: var(--vermelho); }

        @@media (max-width: 992px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.show { transform: translateX(0); }
            #topbar, #main-content { left: 0; margin-left: 0; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <aside id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo">I</div>
            <span class="brand-text">I<span>valid</span></span>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-title">Principal</div>
            <a class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <span class="icon"><i class="fas fa-home"></i></span>
                Dashboard
            </a>

            <div class="nav-section-title">Gestão</div>
            <a class="sidebar-link @(ViewData["ActivePage"]?.ToString() == "Produto" ? "active" : "")"
               asp-controller="Produto" asp-action="Index">
                <span class="icon"><i class="fas fa-box-open"></i></span>
                Produtos
            </a>

            <div class="nav-section-title">Alertas</div>
            <a class="sidebar-link" href="#">
                <span class="icon"><i class="fas fa-fire" style="color:var(--vermelho)"></i></span>
                Próx. Vencimento
                <span class="badge-count">!</span>
            </a>
            <a class="sidebar-link" href="#">
                <span class="icon"><i class="fas fa-exclamation-triangle" style="color:var(--amarelo)"></i></span>
                Em Promoção
            </a>
            <a class="sidebar-link" href="#">
                <span class="icon"><i class="fas fa-check-circle" style="color:var(--verde)"></i></span>
                Estoque OK
            </a>

            <div class="nav-section-title">Sistema</div>
            <a class="sidebar-link" href="#">
                <span class="icon"><i class="fas fa-cog"></i></span>
                Configurações
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-avatar">A</div>
            <div>
                <div class="user-name">Administrador</div>
                <div class="user-role">Super Admin</div>
            </div>
        </div>
    </aside>

    <header id="topbar">
        <div>
            <div class="topbar-title">@(ViewData["PageTitle"] ?? ViewData["Title"] ?? "Painel")</div>
            <div class="topbar-subtitle">@(ViewData["PageSubtitle"] ?? "Painel de controle IValid")</div>
        </div>
        <div class="topbar-actions">
            <button class="topbar-icon-btn" title="Buscar">
                <i class="fas fa-search"></i>
            </button>
            <button class="topbar-icon-btn" title="Notificações">
                <i class="fas fa-bell"></i>
                <span class="notif-dot"></span>
            </button>
            <div class="user-avatar">A</div>
        </div>
    </header>

    <main id="main-content">
        <div class="page-wrapper">
            @if (TempData["Sucesso"] != null)
            {
                <div class="alert-admin success mb-4">
                    <i class="fas fa-check-circle"></i> @TempData["Sucesso"]
                </div>
            }
            @if (TempData["Erro"] != null)
            {
                <div class="alert-admin danger mb-4">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Erro"]
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
