<div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
            <div class="modal-body text-center p-4">
                <div class="mb-3">
                    <div style="width: 60px; height: 60px; background: var(--vermelho-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto; color: var(--vermelho); font-size: 24px;">
                        <i class="fas fa-sign-out-alt"></i>
                    </div>
                </div>
                <h5 class="modal-title mb-2" id="logoutModalLabel" style="font-weight: 700; color: #1a1a2e;">Sair do Painel</h5>
                <p style="color: var(--text-muted-custom); font-size: 14px; margin-bottom: 24px;">Tem certeza que deseja encerrar sua sessão atual?</p>
                
                <form asp-controller="Autenticacao" asp-action="Logout" method="post" style="margin: 0; padding: 0;">
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-light flex-grow-1" data-bs-dismiss="modal" style="border-radius: 10px; font-weight: 600; font-size: 14px; padding: 10px;">Cancelar</button>
                        <button type="submit" class="btn flex-grow-1" style="background: var(--vermelho); color: white; border-radius: 10px; font-weight: 600; font-size: 14px; padding: 10px; border: none; transition: 0.2s;">Sim, sair</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
