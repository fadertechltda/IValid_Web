@model DOMAIN.Model.Usuario.RegistroModel
@{
    Layout = null;
    ViewData["Title"] = "Criar Conta";
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IValid Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --vermelho: #E53935;
            --vermelho-dark: #B71C1C;
            --vermelho-light: #FFEBEE;
            --amarelo: #F9A825;
            --verde: #2E7D32;
            --sidebar-bg: #1a1a2e;
            --text-muted-custom: #8a8fa3;
            --bg-page: #f4f6fb;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-page);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 1000px;
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
            display: flex;
            overflow: hidden;
        }

        .login-image-section {
            flex: 1.2;
            background: linear-gradient(135deg, var(--sidebar-bg) 0%, #0a0a16 100%);
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
            position: relative;
        }

        .login-image-section::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(229,57,53,0.15) 0%, transparent 60%);
            z-index: 1;
            pointer-events: none;
        }

        .brand-logo-large {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--vermelho) 0%, var(--amarelo) 50%, var(--verde) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 32px;
            color: white;
            box-shadow: 0 8px 24px rgba(229,57,53,0.4);
            margin-bottom: 30px;
            position: relative;
            z-index: 2;
        }

        .hero-title {
            font-size: 36px;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }
        
        .hero-title span {
            color: var(--vermelho);
        }

        .hero-subtitle {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.6;
            position: relative;
            z-index: 2;
        }

        .login-form-section {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-header {
            margin-bottom: 30px;
        }

        .login-title {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 8px;
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--text-muted-custom);
        }

        .form-label-custom {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .form-control-custom {
            border: 1.5px solid #e8eaef;
            border-radius: 12px;
            font-size: 14px;
            padding: 10px 14px;
            transition: all 0.2s;
            color: #333;
            background-color: #fcfcfd;
            margin-bottom: 16px;
        }

        .form-control-custom:focus {
            border-color: var(--vermelho);
            box-shadow: 0 0 0 4px rgba(229,57,53,0.1);
            outline: none;
            background-color: white;
        }

        .btn-login {
            background: var(--vermelho);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            padding: 14px;
            font-size: 15px;
            width: 100%;
            transition: all 0.3s;
            margin-top: 10px;
            box-shadow: 0 4px 14px rgba(229,57,53,0.3);
        }

        .btn-login:hover {
            background: var(--vermelho-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(229,57,53,0.4);
        }

        .alert-custom {
            border-radius: 12px;
            border: none;
            font-size: 14px;
            font-weight: 500;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--vermelho-light);
            color: var(--vermelho-dark);
            margin-bottom: 24px;
        }

        .register-link {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: var(--text-muted-custom);
        }

        .register-link a {
            color: var(--vermelho);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

        .register-link a:hover {
            color: var(--vermelho-dark);
        }

        @@media (max-width: 768px) {
            .login-container {
                flex-direction: column;
                max-width: 450px;
            }
            .login-image-section {
                padding: 40px 30px;
                display: none; 
            }
            .login-form-section {
                padding: 40px 30px;
            }
        }
    </style>
</head>
<body>

    <div class="login-container">
        
        <div class="login-image-section">
            <div class="brand-logo-large">I</div>
            <h1 class="hero-title">Gestão Inteligente de <span>Validades</span>.</h1>
            <p class="hero-subtitle">Controle o vencimento dos seus produtos, reduza perdas e maximize seus lucros com o painel administrativo do IValid.</p>
        </div>

        <div class="login-form-section">
            <div class="login-header">
                <h2 class="login-title">Criar Conta</h2>
                <p class="login-subtitle">Preencha os dados abaixo para obter acesso de Administrador.</p>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-custom">
                    <i class="fas fa-exclamation-circle fs-5"></i>
                    <div>
                        @Html.ValidationSummary(false, "", new { @class = "mb-0 list-unstyled p-0 m-0" })
                    </div>
                </div>
            }

            <form asp-controller="Autenticacao" asp-action="Registro" method="post">
                <div>
                    <label asp-for="NomeCompleto" class="form-label-custom">Nome Completo</label>
                    <input asp-for="NomeCompleto" type="text" class="form-control form-control-custom" placeholder="Seu nome" required />
                </div>

                <div>
                    <label asp-for="Email" class="form-label-custom">Email</label>
                    <input asp-for="Email" type="email" class="form-control form-control-custom" placeholder="exemplo@ivalid.com" required autocomplete="username" />
                </div>

                <div>
                    <label asp-for="Senha" class="form-label-custom">Senha</label>
                    <input asp-for="Senha" type="password" class="form-control form-control-custom" placeholder="••••••••" required autocomplete="new-password" />
                </div>

                <div>
                    <label asp-for="ConfirmarSenha" class="form-label-custom">Confirmar Senha</label>
                    <input asp-for="ConfirmarSenha" type="password" class="form-control form-control-custom" placeholder="••••••••" required autocomplete="new-password" />
                </div>

                <button type="submit" class="btn-login">
                    Criar Conta <i class="fas fa-check ms-2"></i>
                </button>
            </form>

            <div class="register-link">
                Já tem uma conta? <a asp-controller="Autenticacao" asp-action="Login">Fazer login</a>
            </div>
        </div>
    </div>

</body>
</html>
